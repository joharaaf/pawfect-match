<%- include('partials/header') %>
<link rel="stylesheet" href="/css/adopt.css">

<main id="main-content" class="section">
  <div class="container">
    <h1>🐾 Adopt a Pet Today!</h1>
    <p class="section-subtitle">Find your perfect companion and start your adoption journey</p>

    <!-- Hero Section -->
    <div class="adopt-hero">
      <h2>🏡 Ready to Change a Life?</h2>
      <p>Every pet deserves a loving home. When you adopt, you're not just getting a pet – you're gaining a loyal friend and saving a life. Our adoption process is designed to help you find the perfect match for your family.</p>
    </div>

    <!-- How It Works -->
    <section class="process-section">
      <h2>📝 How Adoption Works</h2>
      <div class="process-steps">
        <article class="step-card">
          <div class="step-number">1️⃣</div>
          <h3>🔍 Browse Available Pets</h3>
          <p>Use our Adoption Finder to search for pets by type, age, and adoption plan. Filter by your preferences to find the perfect match.</p>
          <a href="/#adoption-finder" class="btn">Start Browsing</a>
        </article>

        <article class="step-card">
          <div class="step-number">2️⃣</div>
          <h3>📋 Choose Your Plan</h3>
          <p>Select an adoption plan that fits your situation: Basic Adoption, Foster-to-Adopt, or Forever Home Support.</p>
          <a href="/plan-details" class="btn">View Plans</a>
        </article>

        <article class="step-card">
          <div class="step-number">3️⃣</div>
          <h3>💬 Contact Us</h3>
          <p>Reach out through our support form with questions or to start the adoption process. We'll guide you every step of the way!</p>
          <a href="/support" class="btn">Contact Support</a>
        </article>
      </div>
    </section>

    <!-- Success Stories -->
    <section class="success-stories">
      <h2>🌟 Happy Families</h2>
      <p class="section-subtitle">Real stories from families who found their perfect companions</p>
      
      <div class="stories-grid">
        <article class="story-card">
          <div class="story-icon">🐕</div>
          <h3>The Johnson Family & Max</h3>
          <p>"We adopted Max through the Foster-to-Adopt plan. He's been with us for 6 months now and we can't imagine life without him! The trial period helped us make sure he was the right fit."</p>
          <div class="story-meta">⭐⭐⭐⭐⭐ - Sarah J., Riyadh</div>
        </article>

        <article class="story-card">
          <div class="story-icon">🐱</div>
          <h3>Ahmed & Luna</h3>
          <p>"Luna was my first pet adoption. The Basic Adoption plan made the process simple and affordable. The post-adoption guide was incredibly helpful for a first-time pet owner!"</p>
          <div class="story-meta">⭐⭐⭐⭐⭐ - Ahmed M., Jeddah</div>
        </article>

        <article class="story-card">
          <div class="story-icon">🐰</div>
          <h3>The Al-Rashid Family & Cotton</h3>
          <p>"We chose the Forever Home Support plan for Cotton. The training resources and vet discounts have been amazing. Our rabbit is thriving and the kids are learning responsibility!"</p>
          <div class="story-meta">⭐⭐⭐⭐⭐ - Fatima R., Dammam</div>
        </article>
      </div>
    </section>

    <!-- Why Adopt? -->
    <section class="why-adopt">
      <h2>❤️ Why Adopt from Pawfect Match?</h2>
      <div class="benefits-grid">
        <div class="benefit-item">
          <span class="benefit-icon">🏥</span>
          <h3>Healthy Pets</h3>
          <p>All pets are health-checked and vaccinated</p>
        </div>
        <div class="benefit-item">
          <span class="benefit-icon">👥</span>
          <h3>Expert Support</h3>
          <p>Guidance from adoption experts throughout the process</p>
        </div>
        <div class="benefit-item">
          <span class="benefit-icon">💰</span>
          <h3>Affordable Plans</h3>
          <p>Flexible adoption plans to fit any budget</p>
        </div>
        <div class="benefit-item">
          <span class="benefit-icon">🎓</span>
          <h3>Training Resources</h3>
          <p>Access to training guides and pet care tips</p>
        </div>
        <div class="benefit-item">
          <span class="benefit-icon">🤝</span>
          <h3>Community</h3>
          <p>Join our community of pet lovers and adopters</p>
        </div>
        <div class="benefit-item">
          <span class="benefit-icon">✅</span>
          <h3>Perfect Matches</h3>
          <p>We help you find the right pet for your lifestyle</p>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="cta-section">
      <div class="cta-box">
        <h2>🎉 Ready to Start Your Journey?</h2>
        <p>Browse our available pets and find your perfect companion today!</p>
        <div class="cta-buttons">
          <a href="/#adoption-finder" class="btn btn-primary">🔍 Browse Pets Now</a>
          <a href="/support" class="btn">💬 Contact Us</a>
        </div>
      </div>
    </section>

  </div>
</main>

<%- include('partials/footer') %>
