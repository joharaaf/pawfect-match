<%- include('partials/header', { pageTitle: 'Adoption Plans', activePage: 'plans' }) %>

<main id="main-content" class="section">
  <div class="container">
    <h1>Adoption Plans</h1>
    <p>Select the plan that fits your situation. Fees and availability may vary by shelter. <span aria-hidden="true">🫂</span></p>

    <% if (typeof success !== 'undefined' && success) { %>
    <div class="message-banner message-success">
      <%= success %>
    </div>
    <% } %>
    
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="message-banner message-error">
      <%= error %>
    </div>
    <% } %>

    <!-- Quick anchors -->
    <nav aria-label="Plan sections" class="subnav">
      <ul>
        <li><a href="#forever"><span aria-hidden="true">🥇</span> Forever Home Support</a></li>
        <li><a href="#foster"><span aria-hidden="true">🥈</span> Foster-to-Adopt</a></li>
        <li><a href="#basic"><span aria-hidden="true">🥉</span> Basic Adoption</a></li>
      </ul>
    </nav>

    <!-- Plan 1 -->
    <article id="forever" class="plan-detail">
      <h2><span aria-hidden="true">🥇</span> Forever Home Support</h2>
      <p>Extra resources to help you and your pet thrive long-term. Ideal for first-time adopters.</p>
      <ul>
        <li>Suggested donation: ~ <strong>350 SAR</strong></li>
        <li>Training & behavior resources library</li>
        <li>Partner vet discount list</li>
        <li>Community forum access for tips and Q&A</li>
      </ul>
      <a class="btn" href="/support">Ask about Forever Home Support</a>
    </article>

    <!-- Plan 2 -->
    <article id="foster" class="plan-detail">
      <h2><span aria-hidden="true">🥈</span> Foster-to-Adopt</h2>
      <p>Try a short foster period at home before finalizing adoption. Great if you want a trial run.</p>
      <ul>
        <li>Fee: ~ <strong>0–100 SAR</strong> (often reduced during foster)</li>
        <li>Home trial period with check-ins from the shelter</li>
        <li>Starter supplies checklist provided</li>
        <li>Option to finalize adoption or continue fostering</li>
      </ul>
      <a class="btn" href="/support">Ask about Foster-to-Adopt</a>
    </article>

    <!-- Plan 3 -->
    <article id="basic" class="plan-detail">
      <h2><span aria-hidden="true">🥉</span> Basic Adoption</h2>
      <p>Standard adoption process through partner shelters. Best for families ready to commit now.</p>
      <ul>
        <li>Fee: ~ <strong>200 SAR</strong> (varies by shelter)</li>
        <li>Includes health check, core vaccines, and microchip</li>
        <li>Standard paperwork & adoption counseling</li>
        <li>Post-adoption care guide</li>
      </ul>
      <a class="btn" href="/support">Ask about Basic Adoption</a>
    </article>

    <p><a href="#main-content">Back to top ↑</a></p>

    <hr class="section-divider" />

    <!-- Available Plans Section -->
<section id="current-plans" class="section">
  <div class="container">
    <div class="plans-header">
      <h2>Available Plans</h2>
      <p>Choose the perfect plan for your adoption journey</p>
    </div>

    <div class="pricing-cards-grid">
      <% 
      // Core 3 plans - always displayed
      var corePlans = [
        {
          name: 'Forever Home Support',
          price: 350.00,
          description: 'Extra resources to help you and your pet thrive long-term. Ideal for first-time adopters.',
          tier: 'Premium',
          icon: '🥇',
          class: 'pricing-card-forever'
        },
        {
          name: 'Foster-to-Adopt',
          price: 50.00,
          description: 'Try a short foster period at home before finalizing adoption. Great if you want a trial run.',
          tier: 'Popular',
          icon: '🥈',
          class: 'pricing-card-foster'
        },
        {
          name: 'Basic Adoption',
          price: 200.00,
          description: 'Standard adoption process through partner shelters. Best for families ready to commit now.',
          tier: 'Essential',
          icon: '🥉',
          class: 'pricing-card-basic'
        }
      ];

      // Display the 3 core plans
      corePlans.forEach(function(p) { %>
        <article class="pricing-card <%= p.class %>">
          <div class="pricing-header">
            <span class="tier-label"><span aria-hidden="true"><%= p.icon %></span> <%= p.tier %></span>
            <h3 class="plan-name"><%= p.name %></h3>
          </div>
          
          <div class="pricing-amount">
            <span class="price"><%= Number(p.price).toFixed(2) %></span>
            <span class="currency">SAR</span>
          </div>
          
          <div class="plan-description">
            <p><%= p.description %></p>
          </div>
          
          <div class="plan-footer">
            <a href="/support" class="btn-plan">Get Started</a>
          </div>
        </article>
      <% }); %>

      <% 
      // Display any additional custom plans from database (if available)
      if (typeof plans !== 'undefined' && plans && plans.length) {
        plans.forEach(function(p) { %>
          <article class="pricing-card pricing-card-default">
            <div class="pricing-header">
              <span class="tier-label">Custom</span>
              <h3 class="plan-name"><%= p.name %></h3>
            </div>
            
            <div class="pricing-amount">
              <span class="price"><%= Number(p.price).toFixed(2) %></span>
              <span class="currency">SAR</span>
            </div>
            
            <div class="plan-description">
              <p><%= p.description %></p>
            </div>
            
            <div class="plan-footer">
              <a href="/support" class="btn-plan">Get Started</a>
            </div>
          </article>
        <% });
      } %>
    </div>
  </div>
</section>

    <hr class="section-divider" />

    <section aria-label="Manage plans">
      <h2>Manage Plans (Admin)</h2>

      <div class="form-grid">

        <div class="form-card">
    
<section id="add-plan" class="section">
  <div class="container">
    <h3>Add New Plan</h3>

    <form id="planForm" action="/plans" method="POST" class="form-card">
      <div class="form-row">
        <label for="planName">Plan Name:</label>
        <input type="text" id="planName" name="planName" required>
      </div>

      <div class="form-row">
        <label for="price">Price (SAR):</label>
        <input
          type="number"
          id="price"
          name="price"
          step="0.01"
          min="1"
          required
        >
      </div>

      <div class="form-row">
        <label for="description">Description:</label>
        <textarea
          id="description"
          name="description"
          rows="3"
          required
        ></textarea>
      </div>

      <div class="form-actions">
        <button class="btn" type="submit">Add Plan</button>
      </div>
    </form>
  </div>
</section>

        </div>
      </div>
    </section>
  </div>
</main>

<script src="/js/form-validation.js"></script>
<%- include('partials/footer') %>